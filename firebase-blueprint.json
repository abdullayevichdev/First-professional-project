{
  "entities": {
    "user": {
      "title": "User",
      "description": "System user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "last_login": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "role", "status"]
    },
    "content": {
      "title": "Content",
      "description": "Articles and news",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["article", "news", "speech"] },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "title_uz": { "type": "string" },
        "title_ru": { "type": "string" },
        "title_en": { "type": "string" },
        "excerpt_uz": { "type": "string" },
        "body_uz": { "type": "string" },
        "image_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "activity": {
      "title": "Activity Log",
      "description": "User actions log",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "event_type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "submission": {
      "title": "Article Submission",
      "description": "User submitted articles",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "user",
      "description": "User profiles"
    },
    "content": {
      "schema": "content",
      "description": "Public content items"
    },
    "activity": {
      "schema": "activity",
      "description": "Admin activity logs"
    },
    "submissions": {
      "schema": "submission",
      "description": "User article submissions"
    },
    "notifications": {
      "schema": "notification",
      "description": "Targeted notifications"
    },
    "newsletter": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Email subscribers"
    },
    "messages": {
      "schema": { "type": "object", "properties": { "to": { "type": "string" }, "message": { "type": "string" } } },
      "description": "Admin to user messages"
    }
  }
}
