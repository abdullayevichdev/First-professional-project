{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Content": {
      "title": "Content",
      "description": "Articles and media content",
      "type": "object",
      "properties": {
        "title_uz": { "type": "string" },
        "title_ru": { "type": "string" },
        "title_en": { "type": "string" },
        "body_uz": { "type": "string" },
        "body_ru": { "type": "string" },
        "body_en": { "type": "string" },
        "category": { "type": "string" },
        "image_url": { "type": "string" },
        "video_url": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Submission": {
      "title": "Submission",
      "description": "User submitted articles for review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Contact form messages",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "Admin activity logs",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Newsletter": {
      "title": "Newsletter",
      "description": "Newsletter subscriptions",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "content": { "schema": "Content", "description": "Published articles" },
    "submissions": { "schema": "Submission", "description": "Article submissions" },
    "notifications": { "schema": "Notification", "description": "User notifications" },
    "messages": { "schema": "Message", "description": "Contact messages" },
    "activity": { "schema": "Activity", "description": "Admin logs" },
    "newsletter": { "schema": "Newsletter", "description": "Email subscriptions" }
  }
}
