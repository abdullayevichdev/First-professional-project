rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin check: Must be signed in, email verified, and in the whitelist
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email in [
               'mansur.ox7@gmail.com', 
               'abdulxayavazxanov2012@gmail.com'
             ];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      // Identity Protection: Users can only see their own profile or if they are admin
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      // Creation: Strictly validated
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.keys().hasAll(['username', 'role', 'status']) &&
                    request.resource.data.role == 'user';
                    
      // Update: Tiered permissions
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == userId && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'name', 'picture', 'phone', 'birthDate', 'saved_articles', 'last_login', 'password'
         ]))
      );
      
      allow delete: if isAdmin();
    }

    // Content Collection
    match /content/{contentId} {
      // Allow public read for content to ensure visibility even if auth token isn't passed to server
      allow read: if true;
      
      // Admins only for writes
      allow create: if isAdmin() && isValidId(contentId) &&
                    request.resource.data.keys().hasAll(['type', 'title_uz']) &&
                    request.resource.data.type is string &&
                    request.resource.data.title_uz is string && 
                    request.resource.data.title_uz.size() <= 500;
                    
      allow update: if isAdmin() && 
                    request.resource.data.type is string &&
                    request.resource.data.title_uz.size() <= 500;
                    
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      // Allow user to mark as read
      allow update: if (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])));
      allow delete: if isAdmin();
    }

    // Submissions
    match /submissions/{subId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Newsletter (Public can subscribe)
    match /newsletter/{subId} {
      allow create: if request.resource.data.email is string && request.resource.data.email.size() < 255;
      allow read, update, delete: if isAdmin();
    }

    // Activity Logs
    match /activity/{activityId} {
      allow read: if isAdmin();
      allow create: if true; // Allow logging from any source
      allow update, delete: if false;
    }

    // Messages (Contact form/Chat)
    match /messages/{msgId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() || isAdmin(); 
      allow update, delete: if isAdmin();
    }
  }
}
